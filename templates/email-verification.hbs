<!doctype html>
<html lang="en" xmlns="http://www.w3.org/1999/xhtml" xmlns:v="urn:schemas-microsoft-com:vml" xmlns:o="urn:schemas-microsoft-com:office:office">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="x-apple-disable-message-reformatting" />
    <title>Your verification code</title>
    <!--[if mso]>
      <style type="text/css">
        table {
          border-collapse: collapse;
        }
        .outlook-font-fix {
          font-family: Arial, sans-serif;
        }
      </style>
    <![endif]-->
    <style type="text/css">
      /* Reset styles */
      body,
      table,
      td,
      a {
        -webkit-text-size-adjust: 100%;
        -ms-text-size-adjust: 100%;
      }
      table,
      td {
        mso-table-lspace: 0pt;
        mso-table-rspace: 0pt;
      }
      img {
        -ms-interpolation-mode: bicubic;
        border: 0;
        height: auto;
        line-height: 100%;
        outline: none;
        text-decoration: none;
      }
      body {
        margin: 0 !important;
        padding: 0 !important;
        width: 100% !important;
        height: 100% !important;
      }

      /* Base styles */
      body {
        background-color: #f6f6f6;
        font-family: Arial, sans-serif;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }

      /* Container */
      .email-container {
        max-width: 698px;
        margin: 0 auto;
      }

      /* Content card */
      .content-card {
        background-color: #f4f3f3;
        border-radius: 44px;
        padding: 50px 64px;
      }

      /* Typography */
      .heading {
        font-family: Arial, sans-serif;
        font-weight: 700;
        font-size: 24px;
        line-height: 1em;
        letter-spacing: -0.72px;
        color: #1a1a1a;
        text-align: center;
        margin: 0 0 24px 0;
        padding: 0;
      }

      .body-text {
        font-family: Arial, sans-serif;
        font-weight: 400;
        font-size: 16px;
        line-height: 1.3em;
        letter-spacing: -0.16px;
        color: #1a1a1a;
        text-align: center;
        margin: 0;
        padding: 0;
      }

      /* Verification code box */
      .verification-code-container {
        background-color: #ffffff;
        border: 1px solid rgba(0, 0, 0, 0.12);
        border-radius: 8px;
        padding: 24px 32px;
        display: inline-block;
      }

      .verification-code {
        font-family: Arial, sans-serif;
        font-weight: 700;
        font-size: 24px;
        line-height: 1em;
        letter-spacing: -0.72px;
        color: #0b0b0b;
        letter-spacing: 16px;
      }

      /* Footer */
      .footer-text {
        font-family: Arial, sans-serif;
        font-weight: 400;
        font-size: 12px;
        line-height: 1.33em;
        color: #999999;
        text-align: center;
        margin: 0;
        padding: 0;
      }

      /* Spacing */
      .spacer-32 {
        height: 32px;
        line-height: 32px;
        font-size: 32px;
      }

      /* Mobile responsive */
      @media only screen and (max-width: 600px) {
        .email-container {
          width: 100% !important;
        }
        .content-card {
          padding: 30px 24px !important;
          border-radius: 24px !important;
        }
        .heading {
          font-size: 20px !important;
        }
        .body-text {
          font-size: 14px !important;
        }
        .verification-code {
          font-size: 20px !important;
          letter-spacing: 12px !important;
        }
        .verification-code-container {
          padding: 16px 24px !important;
        }
      }
    </style>
  </head>
  <body style="margin: 0; padding: 0; background-color: #ffffff">
    <!-- Preheader text -->
    <div style="display: none; max-height: 0; overflow: hidden; mso-hide: all">Your verification code for Memories</div>

    <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%">
      <tr>
        <td style="padding: 32px 20px">
          <table role="presentation" cellspacing="0" cellpadding="0" border="0" class="email-container" align="center" style="max-width: 698px; width: 100%">
            <!-- Logo -->
            <tr>
              <td style="text-align: center; padding-bottom: 32px">
                <img
                  src="{{BASE_URL}}/templates/dark-logo.png"
                  alt="Memories"
                  width="396"
                  height="84"
                  style="display: inline-block; max-width: 132px; width: 100%; height: auto"
                />
              </td>
            </tr>

            <!-- Main Content Card -->
            <tr>
              <td class="content-card" style="background-color: #f4f3f3; border-radius: 44px; padding: 50px 64px">
                <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%">
                  <!-- Heading -->
                  <tr>
                    <td>
                      <h1
                        class="heading outlook-font-fix"
                        style="
                          font-family: Arial, sans-serif;
                          font-weight: 700;
                          font-size: 24px;
                          line-height: 1em;
                          letter-spacing: -0.72px;
                          color: #1a1a1a;
                          text-align: center;
                          margin: 0 0 24px 0;
                          padding: 0;
                        "
                      >
                        Your verification code is:
                      </h1>
                    </td>
                  </tr>

                  <!-- Verification Code -->
                  <tr>
                    <td style="text-align: center">
                      <div
                        class="verification-code-container"
                        style="background-color: #ffffff; border: 1px solid rgba(0, 0, 0, 0.12); border-radius: 8px; padding: 24px 32px; display: inline-block"
                      >
                        <span
                          class="verification-code outlook-font-fix"
                          style="
                            font-family: Arial, sans-serif;
                            font-weight: 700;
                            font-size: 24px;
                            white-space-collapse: discard;
                            line-height: 1em;
                            letter-spacing: -0.72px;
                            color: #0b0b0b;
                            display: flex;
                          "
                        >
                          {{#each code}}{{this}}{{#unless @last}}<span style="display: inline-block; width: 16px"></span>{{/unless}}{{/each}}
                        </span>
                      </div>
                    </td>
                  </tr>

                  <!-- Body Text -->
                  <tr>
                    <td style="padding-top: 24px">
                      <p
                        class="body-text outlook-font-fix"
                        style="
                          font-family: Arial, sans-serif;
                          font-weight: 400;
                          font-size: 16px;
                          line-height: 1.3em;
                          letter-spacing: -0.16px;
                          color: #1a1a1a;
                          text-align: center;
                          margin: 0;
                          padding: 0;
                        "
                      >
                        Enter it on the website to finish creating your account.<br />
                        If you didn't request this email — just ignore it.
                      </p>
                    </td>
                  </tr>
                </table>
              </td>
            </tr>

            <!-- Footer -->
            <tr>
              <td style="padding: 32px 0 0 0">
                <p
                  class="footer-text outlook-font-fix"
                  style="font-family: Arial, sans-serif; font-weight: 400; font-size: 12px; line-height: 1.33em; color: #999999; text-align: center; margin: 0; padding: 0"
                >
                  © {{year}} Memories. All rights reserved.
                </p>
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
