<html lang="en" xmlns="http://www.w3.org/1999/xhtml" xmlns:v="urn:schemas-microsoft-com:vml" xmlns:o="urn:schemas-microsoft-com:office:office">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="x-apple-disable-message-reformatting" />
    <title>You've received a card</title>
    <!--[if mso]>
      <style type="text/css">
        table {
          border-collapse: collapse;
        }
        .outlook-font-fix {
          font-family: Arial, sans-serif;
        }
      </style>
    <![endif]-->
    <style type="text/css">
      /* Reset styles */
      body,
      table,
      td,
      a {
        -webkit-text-size-adjust: 100%;
        -ms-text-size-adjust: 100%;
      }
      table,
      td {
        mso-table-lspace: 0pt;
        mso-table-rspace: 0pt;
      }
      img {
        -ms-interpolation-mode: bicubic;
        border: 0;
        height: auto;
        line-height: 100%;
        outline: none;
        text-decoration: none;
      }
      body {
        margin: 0 !important;
        padding: 0 !important;
        width: 100% !important;
        height: 100% !important;
      }

      /* Base styles */
      body {
        background-color: #f6f6f6;
        font-family: Arial, sans-serif;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }

      /* Container */
      .email-container {
        max-width: 698px;
        margin: 0 auto;
      }

      /* Content card */
      .content-card {
        background-color: #ffffff;
        border: 1px solid rgba(252, 67, 15, 0.3);
        border-radius: 44px;
        padding: 50px 64px;
      }

      /* Typography */
      .heading {
        font-family: Arial, sans-serif;
        font-weight: 700;
        font-size: 24px;
        line-height: 1em;
        letter-spacing: -0.72px;
        color: #1a1a1a;
        text-align: center;
        margin: 0 0 16px 0;
        padding: 0;
      }

      .body-text {
        font-family: Arial, sans-serif;
        font-weight: 400;
        font-size: 16px;
        line-height: 1.3em;
        letter-spacing: -0.16px;
        color: #1a1a1a;
        text-align: center;
        margin: 0 0 40px 0;
        padding: 0;
      }

      /* CTA Button */
      .cta-button {
        background-color: #ff4612;
        border: 1px solid #ff4612;
        border-radius: 43px;
        box-shadow: 0px 2px 26px 0px rgba(255, 70, 18, 0.49);
        padding: 15px 40px;
        text-align: center;
        text-decoration: none;
        display: inline-block;
        font-family: Inter, Arial, sans-serif;
        font-weight: 600;
        font-size: 23px;
        line-height: 1.21em;
        letter-spacing: -0.92px;
        color: #ffffff !important;
        margin: 0 0 40px 0;
      }

      .cta-button:hover {
        background-color: #e63f0f;
        border-color: #e63f0f;
      }

      /* Info box */
      .info-box {
        background-color: #f4f4f4;
        border-radius: 14px;
        padding: 12px 24px 12px 12px;
        text-align: center;
      }

      .info-icon {
        width: 24px;
        height: 24px;
        margin: 0 auto 12px auto;
        display: block;
      }

      .info-text {
        font-family: Arial, sans-serif;
        font-weight: 400;
        font-size: 12px;
        line-height: 1.3em;
        letter-spacing: -0.12px;
        color: #1a1a1a;
        text-align: center;
        margin: 0;
        padding: 0;
      }

      /* Footer */
      .footer-text {
        font-family: Arial, sans-serif;
        font-weight: 400;
        font-size: 12px;
        line-height: 1.33em;
        color: #999999;
        text-align: center;
        margin: 32px 0 0 0;
        padding: 0;
      }

      /* Spacing */
      .spacer-32 {
        height: 32px;
        line-height: 32px;
        font-size: 32px;
      }

      /* Mobile responsive */
      @media only screen and (max-width: 600px) {
        .email-container {
          width: 100% !important;
        }
        .content-card {
          padding: 30px 24px !important;
          border-radius: 24px !important;
        }
        .heading {
          font-size: 20px !important;
        }
        .body-text {
          font-size: 14px !important;
        }
        .cta-button {
          font-size: 18px !important;
          padding: 12px 30px !important;
        }
      }
    </style>
  </head>
  <body style="margin: 0; padding: 0; background-color: #f6f6f6">
    <!-- Preheader text -->
    <div style="display: none; max-height: 0; overflow: hidden; mso-hide: all">You've received a letter from a friend. Click to open and view your message.</div>

    <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="background-color: #f6f6f6">
      <tr>
        <td style="padding: 32px 20px">
          <table role="presentation" cellspacing="0" cellpadding="0" border="0" class="email-container" align="center" style="max-width: 698px; width: 100%">
            <!-- Logo -->
            <tr>
              <td style="text-align: center; padding-bottom: 32px">
                <img src="{{BASE_URL}}/templates/logo.png" alt="Memories" width="396" height="84" style="display: inline-block; max-width: 396px; width: 100%; height: auto" />
              </td>
            </tr>

            <!-- Main Content Card -->
            <tr>
              <td class="content-card" style="background-color: #ffffff; border: 1px solid rgba(252, 67, 15, 0.3); border-radius: 44px; padding: 50px 64px">
                <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%">
                  <!-- Heading -->
                  <tr>
                    <td>
                      <h1
                        class="heading outlook-font-fix"
                        style="
                          font-family: Arial, sans-serif;
                          font-weight: 700;
                          font-size: 24px;
                          line-height: 1em;
                          letter-spacing: -0.72px;
                          color: #1a1a1a;
                          text-align: center;
                          margin: 0 0 16px 0;
                          padding: 0;
                        "
                      >
                        Hello,<br />
                        You've received a letter from<br />
                        {{#with payee}}
                          <span style="display: inline-block">{{name}}</span><br />
                          <span style="display: inline-block">({{email}})</span>
                        {{/with}}
                      </h1>
                    </td>
                  </tr>

                  <!-- Body Text -->
                  <tr>
                    <td>
                      <p
                        class="body-text outlook-font-fix"
                        style="
                          font-family: Arial, sans-serif;
                          font-weight: 400;
                          font-size: 16px;
                          line-height: 1.3em;
                          letter-spacing: -0.16px;
                          color: #1a1a1a;
                          text-align: center;
                          margin: 0 0 40px 0;
                          padding: 0;
                        "
                      >
                        Click below to open your letter and view the message.
                      </p>
                    </td>
                  </tr>

                  <!-- CTA Button -->
                  <tr>
                    <td style="text-align: center">
                      <!--[if mso]>
                        <v:roundrect
                          xmlns:v="urn:schemas-microsoft-com:vml"
                          xmlns:w="urn:schemas-microsoft-com:office:word"
                          href="{CAPSULE_URL}"
                          style="height: 67px; v-text-anchor: middle; width: 338px"
                          arcsize="63%"
                          stroke="f"
                          fillcolor="#FF4612"
                        >
                          <w:anchorlock />
                          <center style="color: #ffffff; font-family: Inter, Arial, sans-serif; font-size: 23px; font-weight: 600">Open your card</center>
                        </v:roundrect>
                      <![endif]-->
                      <!--[if !mso]><!-->
                      <a
                        href="{{url}}"
                        class="cta-button"
                        style="
                          background-color: #ff4612;
                          border: 1px solid #ff4612;
                          border-radius: 43px;
                          box-shadow: 0px 2px 26px 0px rgba(255, 70, 18, 0.49);
                          padding: 15px 40px;
                          text-align: center;
                          text-decoration: none;
                          display: inline-block;
                          font-family: Inter, Arial, sans-serif;
                          font-weight: 600;
                          font-size: 23px;
                          line-height: 1.21em;
                          letter-spacing: -0.92px;
                          color: #ffffff;
                          margin: 0 0 40px 0;
                        "
                      >
                        Open your letter
                      </a>
                      <!--<![endif]-->
                    </td>
                  </tr>

                  <!-- Info Box -->
                  <tr>
                    <td class="info-box" style="background-color: #f4f4f4; border-radius: 14px; padding: 12px 24px">
                      <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%">
                        <tr>
                          <td style="text-align: center; padding-bottom: 12px">
                            <!-- Info Icon SVG -->
                            <img src="{{BASE_URL}}/templates/lock.png" alt="Memories" width="24" height="24" style="display: inline-block;" />
                          </td>
                        </tr>
                        <tr>
                          <td>
                            <p
                              class="info-text outlook-font-fix"
                              style="
                                font-family: Arial, sans-serif;
                                font-weight: 400;
                                font-size: 12px;
                                line-height: 1.3em;
                                letter-spacing: -0.12px;
                                color: #1a1a1a;
                                text-align: center;
                                margin: 0;
                                padding: 0;
                              "
                            >
                              Your card will open in a secure browser window.<br />
                              If you're not sure why you received this — you may safely ignore this email.
                            </p>
                          </td>
                        </tr>
                      </table>
                    </td>
                  </tr>
                </table>
              </td>
            </tr>

            <!-- Footer -->
            <tr>
              <td>
                <p
                  class="footer-text outlook-font-fix"
                  style="font-family: Arial, sans-serif; font-weight: 400; font-size: 12px; line-height: 1.33em; color: #999999; text-align: center; margin: 32px 0 0 0; padding: 0"
                >
                  ©
                  {{year}}
                  Memories. All rights reserved.
                </p>
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>