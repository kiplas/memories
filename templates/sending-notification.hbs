<!doctype html>
<html lang="en" xmlns="http://www.w3.org/1999/xhtml" xmlns:v="urn:schemas-microsoft-com:vml" xmlns:o="urn:schemas-microsoft-com:office:office">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="x-apple-disable-message-reformatting" />
    <title>Your digital letter has been sent</title>
    <!--[if mso]>
      <style type="text/css">
        table {
          border-collapse: collapse;
        }
        .outlook-font-fix {
          font-family: Arial, sans-serif;
        }
      </style>
    <![endif]-->
    <style type="text/css">
      /* Reset styles */
      body,
      table,
      td,
      a {
        -webkit-text-size-adjust: 100%;
        -ms-text-size-adjust: 100%;
      }
      table,
      td {
        mso-table-lspace: 0pt;
        mso-table-rspace: 0pt;
      }
      img {
        -ms-interpolation-mode: bicubic;
        border: 0;
        height: auto;
        line-height: 100%;
        outline: none;
        text-decoration: none;
      }
      body {
        margin: 0 !important;
        padding: 0 !important;
        width: 100% !important;
        height: 100% !important;
      }

      /* Base styles */
      body {
        background-color: #f6f6f6;
        font-family: Arial, sans-serif;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }

      /* Container */
      .email-container {
        max-width: 698px;
        margin: 0 auto;
      }

      /* Content card */
      .content-card {
        background-color: #f4f3f3;
        border-radius: 44px;
        padding: 50px 64px;
      }

      /* Typography */
      .heading {
        font-family: Arial, sans-serif;
        font-weight: 700;
        font-size: 24px;
        line-height: 1em;
        letter-spacing: -0.72px;
        color: #1a1a1a;
        text-align: center;
        margin: 0 0 16px 0;
        padding: 0;
      }

      .body-text {
        font-family: Arial, sans-serif;
        font-weight: 400;
        font-size: 16px;
        line-height: 1.3em;
        letter-spacing: -0.16px;
        color: #1a1a1a;
        text-align: center;
        margin: 0;
        padding: 0;
      }

      .body-text-small {
        font-family: Arial, sans-serif;
        font-weight: 400;
        font-size: 16px;
        line-height: 1.3em;
        letter-spacing: -0.16px;
        color: #1a1a1a;
        text-align: center;
        margin: 0 0 32px 0;
        padding: 0;
      }

      .thank-you-text {
        font-family: Arial, sans-serif;
        font-weight: 400;
        font-size: 16px;
        line-height: 1.3em;
        letter-spacing: -0.16px;
        color: #1a1a1a;
        text-align: center;
        margin: 0;
        padding: 0;
      }

      /* Capsule Design Title */
      .capsule-title {
        font-family: Inter, Arial, sans-serif;
        font-weight: 600;
        font-size: 16px;
        line-height: 1.21em;
        letter-spacing: -0.64px;
        color: #000000;
        text-align: center;
        margin: 0 0 16px 0;
        padding: 0;
      }

      /* Capsule Image */
      .capsule-image {
        width: 322px;
        height: 240px;
        border-radius: 2px;
        margin: 0 auto 24px auto;
        display: block;
        object-fit: cover;
      }

      /* Info List */
      .info-list {
        width: 100%;
        border-collapse: collapse;
      }

      .info-row {
        border-bottom: 1px solid rgba(0, 0, 0, 0.6);
      }

      .info-row:last-child {
        border-bottom: none;
      }

      .info-label {
        font-family: Inter, Arial, sans-serif;
        font-weight: 600;
        font-size: 14px;
        line-height: 1.21em;
        letter-spacing: -0.56px;
        color: #000000;
        text-align: left;
        padding: 12px 0 8px 0;
        vertical-align: top;
      }

      .info-value {
        font-family: "SF Pro Text", Arial, sans-serif;
        font-weight: 600;
        font-size: 14px;
        line-height: 1.19em;
        letter-spacing: -0.14px;
        color: #71717a;
        text-align: left;
        padding: 12px 0 8px 0;
        vertical-align: top;
      }

      .info-value-dark {
        font-family: Inter, Arial, sans-serif;
        font-weight: 600;
        font-size: 14px;
        line-height: 1.21em;
        letter-spacing: -0.56px;
        color: #000000;
        text-align: right;
        padding: 12px 0 8px 0;
        vertical-align: top;
      }

      .info-value-total {
        font-family: Inter, Arial, sans-serif;
        font-weight: 600;
        font-size: 16px;
        line-height: 1.21em;
        letter-spacing: -0.64px;
        color: #000000;
        text-align: right;
        padding: 12px 0 8px 0;
        vertical-align: top;
      }

      .info-label-total {
        font-family: Inter, Arial, sans-serif;
        font-weight: 600;
        font-size: 16px;
        line-height: 1.21em;
        letter-spacing: -0.64px;
        color: #000000;
        text-align: left;
        padding: 12px 0 8px 0;
        vertical-align: top;
      }

      .info-section {
        padding: 4px 0;
      }

      /* Total Box */
      .total-box {
        border: 1px solid rgba(0, 0, 0, 0.6);
        border-width: 0 0 1px 0;
        padding: 12px 0;
      }

      /* Footer */
      .footer-text {
        font-family: Arial, sans-serif;
        font-weight: 400;
        font-size: 12px;
        line-height: 1.33em;
        color: #999999;
        text-align: center;
        margin: 0;
        padding: 0;
      }

      /* Spacing */
      .spacer-32 {
        height: 32px;
        line-height: 32px;
        font-size: 32px;
      }

      /* Mobile responsive */
      @media only screen and (max-width: 600px) {
        .email-container {
          width: 100% !important;
        }
        .content-card {
          padding: 30px 24px !important;
          border-radius: 24px !important;
        }
        .heading {
          font-size: 20px !important;
        }
        .body-text {
          font-size: 14px !important;
        }
        .capsule-image {
          width: 100% !important;
          height: auto !important;
          max-width: 322px !important;
        }
      }
    </style>
  </head>
  <body style="margin: 0; padding: 0; background-color: #ffffff">
    <!-- Preheader text -->
    <div style="display: none; max-height: 0; overflow: hidden; mso-hide: all">Your digital card has been successfully sent.</div>

    <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%">
      <tr>
        <td style="padding: 32px 20px">
          <table role="presentation" cellspacing="0" cellpadding="0" border="0" class="email-container" align="center" style="max-width: 698px; width: 100%">
            <!-- Logo -->
            <tr>
              <td style="text-align: center; padding-bottom: 32px">
                <img
                  src="{{BASE_URL}}/templates/dark-logo.png"
                  alt="Memories"
                  width="396"
                  height="84"
                  style="display: inline-block; max-width: 132px; width: 100%; height: auto"
                />
              </td>
            </tr>

            <!-- Main Content Card -->
            <tr>
              <td class="content-card" style="background-color: #f4f3f3; border-radius: 44px; padding: 50px 64px">
                <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%">
                  <!-- Heading -->
                  <tr>
                    <td>
                      <h1
                        class="heading outlook-font-fix"
                        style="
                          font-family: Arial, sans-serif;
                          font-weight: 700;
                          font-size: 24px;
                          line-height: 1em;
                          letter-spacing: -0.72px;
                          color: #1a1a1a;
                          text-align: center;
                          margin: 0 0 16px 0;
                          padding: 0;
                        "
                      >
                        {{title}}
                      </h1>
                    </td>
                  </tr>

                  <!-- Body Text -->
                  <tr>
                    <td>
                      <p
                        class="body-text-small outlook-font-fix"
                        style="
                          font-family: Arial, sans-serif;
                          font-weight: 400;
                          font-size: 16px;
                          line-height: 1.3em;
                          letter-spacing: -0.16px;
                          color: #1a1a1a;
                          text-align: center;
                          margin: 0 0 32px 0;
                          padding: 0;
                        "
                      >
                        <br />
                        Hello,<br />
                        Your digital {{product}} has been successfully sent.<br />
                        It will be available for the recipient to open instantly.
                      </p>
                    </td>
                  </tr>

                  <!-- Capsule Design Title -->
                  <tr>
                    <td>
                      <p
                        class="capsule-title outlook-font-fix"
                        style="
                          font-family: Inter, Arial, sans-serif;
                          font-weight: 500;
                          font-size: 16px;
                          line-height: 1.21em;
                          letter-spacing: -0.64px;
                          color: #000000;
                          text-align: center;
                          margin: 0 0 24px 0;
                          padding: 0;
                        "
                      >
                        {{designTitle}}<br />
                        {{illustration}}
                      </p>
                    </td>
                  </tr>

                  <!-- Delivery Addresses & Info -->
                  <tr>
                    <td style="border-top: 1px solid rgba(0, 0, 0, 0.6)">
                      <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" class="info-list">
                        <!-- Delivery Addresses -->
                        {{#each addressees}}
                        <tr>
                          <td class="info-section" style="padding: 4px 0">
                            <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%">
                              <tr>
                                <td
                                  class="info-label"
                                  style="
                                    font-family: Inter, Arial, sans-serif;
                                    font-weight: 600;
                                    font-size: 14px;
                                    line-height: 1.21em;
                                    letter-spacing: -0.56px;
                                    color: #000000;
                                    text-align: left;
                                    padding: 12px 0 4px 0;
                                  "
                                >
                                  Delivery Address {{index}}:
                                </td>
                              </tr>
                              <tr>
                                <td
                                  class="info-value"
                                  style="
                                    font-family: &quot;SF Pro Text&quot;, Arial, sans-serif;
                                    font-weight: 600;
                                    font-size: 14px;
                                    line-height: 1.19em;
                                    letter-spacing: -0.14px;
                                    color: #71717a;
                                    padding: 0px 0 12px 0;
                                  "
                                >
                                  {{address}}
                                </td>
                              </tr>
                            </table>
                          </td>
                        </tr>
                        {{/each}}

                        <!-- Payment -->
                        <tr>
                          <td class="info-row" style="border-bottom: 1px solid rgba(0, 0, 0, 0.6); border-top: 1px solid rgba(0, 0, 0, 0.6)">
                            <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%">
                              <tr>
                                <td
                                  class="info-label"
                                  style="
                                    font-family: Inter, Arial, sans-serif;
                                    font-weight: 600;
                                    font-size: 14px;
                                    line-height: 1.21em;
                                    letter-spacing: -0.56px;
                                    color: #000000;
                                    text-align: left;
                                    padding: 12px 0 4px 0;
                                  "
                                >
                                  Payment:
                                </td>
                              </tr>
                              <tr>
                                <td
                                  class="info-value"
                                  style="
                                    font-family: Inter, Arial, sans-serif;
                                    font-weight: 600;
                                    font-size: 14px;
                                    line-height: 1.21em;
                                    letter-spacing: -0.56px;
                                    color: #71717a;
                                    padding: 0px 0 12px 0;
                                  "
                                >
                                  {{paymentMethod}}
                                </td>
                              </tr>
                            </table>
                          </td>
                        </tr>

                        <!-- Send Date -->
                        <tr>
                          <td class="info-row" style="border-bottom: 1px solid rgba(0, 0, 0, 0.6)">
                            <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%">
                              <tr>
                                <td
                                  class="info-label"
                                  style="
                                    font-family: Inter, Arial, sans-serif;
                                    font-weight: 600;
                                    font-size: 14px;
                                    line-height: 1.21em;
                                    letter-spacing: -0.56px;
                                    color: #000000;
                                    text-align: left;
                                    padding: 12px 0 4px 0;
                                  "
                                >
                                  Send Date:
                                </td>
                              </tr>
                              <tr>
                                <td
                                  class="info-value"
                                  style="
                                    font-family: Inter, Arial, sans-serif;
                                    font-weight: 600;
                                    font-size: 14px;
                                    line-height: 1.21em;
                                    letter-spacing: -0.56px;
                                    color: #71717a;
                                    padding: 0px 0 12px 0;
                                  "
                                >
                                  {{sendDate}}
                                </td>
                              </tr>
                            </table>
                          </td>
                        </tr>

                        <!-- Cards -->
                        <tr>
                          <td class="info-row" style="border-bottom: 1px solid rgba(0, 0, 0, 0.6)">
                            <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%">
                              <tr>
                                <td
                                  class="info-label"
                                  style="
                                    font-family: Inter, Arial, sans-serif;
                                    font-weight: 600;
                                    font-size: 14px;
                                    line-height: 1.21em;
                                    letter-spacing: -0.56px;
                                    color: #000000;
                                    text-align: left;
                                    padding: 12px 0 12px 0;
                                  "
                                >
                                  Cards:
                                </td>
                                <td
                                  class="info-value-dark"
                                  style="
                                    font-family: Inter, Arial, sans-serif;
                                    font-weight: 500;
                                    font-size: 14px;
                                    line-height: 1.21em;
                                    letter-spacing: -0.56px;
                                    color: #000000;
                                    text-align: right;
                                    padding: 12px 0 12px 0;
                                  "
                                >
                                  {{quantity}} × {{price}}
                                </td>
                              </tr>
                            </table>
                          </td>
                        </tr>

                        <!-- Total -->
                        <tr>
                          <td>
                            <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%">
                              <tr>
                                <td
                                  class="info-label-total"
                                  style="
                                    font-family: Inter, Arial, sans-serif;
                                    font-weight: 600;
                                    font-size: 16px;
                                    line-height: 1.21em;
                                    letter-spacing: -0.64px;
                                    color: #000000;
                                    text-align: left;
                                    padding: 12px 0 0px 0;
                                  "
                                >
                                  Total:
                                </td>
                                <td
                                  class="info-value-total"
                                  style="
                                    font-family: Inter, Arial, sans-serif;
                                    font-weight: 600;
                                    font-size: 16px;
                                    line-height: 1.21em;
                                    letter-spacing: -0.64px;
                                    color: #000000;
                                    text-align: right;
                                    padding: 12px 0 0px 0;
                                  "
                                >
                                  {{total}}.
                                </td>
                              </tr>
                            </table>
                          </td>
                        </tr>
                      </table>
                    </td>
                  </tr>

                  <!-- Thank You Text -->
                  <tr>
                    <td style="padding-top: 32px">
                      <p
                        class="thank-you-text outlook-font-fix"
                        style="
                          font-family: Arial, sans-serif;
                          font-weight: 400;
                          font-size: 16px;
                          line-height: 1.3em;
                          letter-spacing: -0.16px;
                          color: #1a1a1a;
                          text-align: center;
                          margin: 0;
                          padding: 0;
                        "
                      >
                        Thank you for using our service.
                      </p>
                    </td>
                  </tr>
                </table>
              </td>
            </tr>

            <!-- Footer -->
            <tr>
              <td style="padding: 0 32px">
                <p
                  class="footer-text outlook-font-fix"
                  style="font-family: Arial, sans-serif; font-weight: 400; font-size: 12px; line-height: 1.33em; color: #999999; text-align: center; margin: 32px 0 0 0; padding: 0"
                >
                  © {{year}} Memories. All rights reserved.
                </p>
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
