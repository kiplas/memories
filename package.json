{
  "name": "memories.com",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "redis": "docker start redis || docker run -d --name redis -p 6379:6379 redis:8-alpine",
    "postgres": "docker start postgres || docker run --name postgres -e POSTGRES_PASSWORD=Admin1234 -e POSTGRES_USER=admin -e POSTGRES_DB=memories -p 5432:5432 -v pgdata:/var/lib/postgresql/data -d postgres:17-alpine",
    "dev": "cross-env pnpm postgres && pnpm redis && next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node ./migrations/index.ts",
    "db:generate-auth-schema": "npx @better-auth/cli@latest generate --output ./db/schema/auth.ts --config ./server/auth/index.ts",
    "db:push": "pnpm drizzle-kit push",
    "stripe": "stripe listen --forward-to localhost:3000/api/payment/webhooks"
  },
  "dependencies": {
    "@gsap/react": "^2.1.2",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@stripe/react-stripe-js": "^5.4.1",
    "@stripe/stripe-js": "^8.6.1",
    "@tanstack/react-query": "^5.90.12",
    "@trpc/client": "^11.8.1",
    "@trpc/server": "^11.8.1",
    "@trpc/tanstack-react-query": "^11.8.1",
    "better-auth": "^1.4.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.1",
    "form-data": "^4.0.5",
    "gsap": "^3.14.2",
    "handlebars": "^4.7.8",
    "input-otp": "^1.4.2",
    "ioredis": "^5.9.3",
    "lenis": "^1.3.17",
    "lucide-react": "^0.562.0",
    "mailgun.js": "^12.7.0",
    "mime-types": "^3.0.2",
    "next": "16.0.8",
    "pg": "^8.16.3",
    "react": "19.2.1",
    "react-dom": "19.2.1",
    "react-image-crop": "^11.0.10",
    "sass": "^1.97.1",
    "stripe": "^20.1.2",
    "superjson": "^2.2.6",
    "tailwind-merge": "^3.4.0",
    "vaul": "^1.1.2",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/mime-types": "^3.0.1",
    "@types/node": "^20",
    "@types/pg": "^8.16.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "baseline-browser-mapping": "^2.9.19",
    "cross-env": "^10.1.0",
    "dotenv": "^17.2.3",
    "drizzle-kit": "^0.31.8",
    "eslint": "^9",
    "eslint-config-next": "16.0.8",
    "prettier": "^3.7.4",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5"
  }
}
